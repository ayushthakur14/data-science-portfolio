   "source": [
    "# Apply broadcasting to add the bonus to every month's sales.\n",
    "import numpy as np\n",
    "\n",
    "sales = np.array([\n",
    "    [120, 150, 180, 200],\n",
    "    [100, 130, 170, 190],\n",
    "    [140, 160, 200, 220]\n",
    "])\n",
    "\n",
    "bonus = np.array([10, 20, 15, 25])\n",
    "\n",
    "bonus_added = sales + bonus\n",
    "print(bonus_added)"
   ]
  }
 ],
