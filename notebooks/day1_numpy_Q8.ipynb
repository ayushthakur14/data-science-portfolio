   "source": [
    "# Use boolean masking to filter numbers greater than 50 in an array.\n",
    "\n",
    "import numpy as np\n",
    "\n",
    "arr = np.array([12,50,66,44,75,84,95,123,500])\n",
    "lar_50 = arr > 50\n",
    "print(arr[lar_50])\n"
   ]
  }
