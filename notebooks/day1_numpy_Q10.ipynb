   "source": [
    "# Using boolean masking, display only the patients whose blood pressure is 140 or above.\n",
    "\n",
    "import numpy as np\n",
    "\n",
    "bp = np.array([118, 135, 142, 128, 150, 122, 138, 145, 117, 160])\n",
    "patients = bp > 140\n",
    "print(bp[patients])"
   ]
  }
